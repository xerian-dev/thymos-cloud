# Required environment variables for Cognito authentication
# These values come from the infrastructure project's Terraform outputs.
#
# To configure locally, copy this file to .env and fill in the values:
#   cp .env.example .env

# AWS Region where Cognito resources are deployed (e.g., us-east-1)
VITE_AWS_REGION=

# Cognito User Pool ID (format: {region}_{poolId}, e.g., us-east-1_aBcDeFgHi)
VITE_COGNITO_USER_POOL_ID=

# Cognito User Pool Client ID (alphanumeric string, e.g., 1a2b3c4d5e6f7g8h9i0j1k2l3m)
VITE_COGNITO_USER_POOL_CLIENT_ID=
